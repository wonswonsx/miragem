# Supabase — Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://bkugwquchpgedxzyslgp.supabase.co

# Chave ANON / PUBLISHABLE apenas (JWT anon legado ou sb_publishable_…).
# NUNCA coloque sb_secret_… nem service_role em variável NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_BIEHEOkvNGJCiyTIieasSA_MaHt1G6h

# Bucket público no Supabase Storage para uploads de vídeo/poster (Admin). Por omissão: videos.
# NEXT_PUBLIC_SUPABASE_STORAGE_BUCKET=videos

# Service Role: só servidor (.env.local, sem NEXT_PUBLIC). Admin Actions usam se definida.
# SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000

# URL pública do site (HTTPS em produção, sem barra no fim). Usada em /api/create-preference (back_urls Mercado Pago)
# e em redirectTo do Supabase Auth (Google OAuth, reset de senha, confirmação de e-mail).
# Na Vercel (produção): https://www.miragemfantasia.com.br
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase Auth — Authentication → URL Configuration (Dashboard):
# Site URL: https://www.miragemfantasia.com.br
# Redirect URLs (adicionar todas):
#   https://www.miragemfantasia.com.br/auth/callback
#   https://www.miragemfantasia.com.br/auth/reset-password
#   http://localhost:3000/auth/callback
#   http://localhost:3000/auth/reset-password
# Google OAuth — Google Cloud Console → Credentials → OAuth 2.0 Client:
#   Authorized redirect URI: https://bkugwquchpgedxzyslgp.supabase.co/auth/v1/callback
#   Authorized JavaScript origins: https://www.miragemfantasia.com.br (+ localhost:3000 em dev)
# Recuperação de senha — Authentication → SMTP Settings: configure SMTP próprio (Resend, SendGrid, etc.)
# O SMTP compartilhado do plano free tem limite baixo e emails podem ir para spam.

# WhatsApp — botão flutuante de suporte (layout global). Número com DDD, só dígitos (ex.: 5511999998888).
NEXT_PUBLIC_WHATSAPP_SUPPORT_NUMBER=
# Mensagem pré-preenchida ao abrir o WhatsApp (opcional).
NEXT_PUBLIC_WHATSAPP_DEFAULT_MESSAGE=Olá, preciso de ajuda com minha conta no Miragem Fantasia.

# Backend Express em `backend/server.js` (diamantes, coleção, Stripe checkout legado).
# Com isso, o Explorar usa GET/POST /api/diamonds e /api/collection com o userId do Supabase.
# Ex.: API na 3002 e Next na 3000 — não use a mesma porta nos dois.
NEXT_PUBLIC_MIRAGE_API_BASE=http://localhost:3002

MP_ACCESS_TOKEN=

# Mercado Pago Public Key (para usar no frontend, se necessário)
NEXT_PUBLIC_MP_PUBLIC_KEY=

# Webhook Mercado Pago: a preferência usa notification_url = {NEXT_PUBLIC_APP_URL}/api/mercadopago-webhook
# (em dev use ngrok ou similar se o MP não alcançar localhost). Crédito de diamantes:
# — com API Express + NEXT_PUBLIC_MIRAGE_API_BASE: defina o mesmo segredo no backend (.env)
# DIAMOND_CREDIT_SECRET=
# — só Supabase: SUPABASE_SERVICE_ROLE_KEY + coluna profiles.diamonds + tabela wallet_transactions

# /admin: user.user_metadata.role === "admin" (Dashboard → Authentication → Users)
